<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}The Twin{% endblock %}</title>
    <link rel="icon" type="image/png" href="{{ asset('medias/thetwin-logo.png') }}">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;900&display=swap" rel="stylesheet">
    {% block stylesheets %}
        {{ encore_entry_link_tags('app') }}
    {% endblock %}
    {% block javascripts %}
        {{ encore_entry_script_tags('app') }}
    {% endblock %}
</head>
<body>
    <nav>
        <a href="{{ path('app_home') }}" class="nav-logo">
            <img src="{{ asset('medias/thetwin-logo.png') }}" alt="The Twin" height="44">
        </a>
        <button class="nav-burger" id="navBurger" aria-label="Menu">
            <span></span>
            <span></span>
            <span></span>
        </button>
        <div class="nav-links" id="navLinks">
            <a href="{{ path('app_collective') }}">Collaborative</a>
            <a href="{{ path('app_twin') }}">MonTwin</a>
            {% if app.user %}
                <a href="{{ path('app_profile') }}">Profil</a>
                <a href="{{ path('app_logout') }}" class="btn-nav">Déconnexion</a>
            {% else %}
                <a href="{{ path('app_login') }}" class="btn-nav">Compte</a>
            {% endif %}
        </div>
    </nav>

    <script>
        document.getElementById('navBurger').addEventListener('click', function() {
            document.getElementById('navLinks').classList.toggle('is-open');
            this.classList.toggle('is-active');
        });
    </script>
    {% block body %}{% endblock %}

    <footer class="footer">
        <a href="{{ path('app_home') }}" class="footer__logo">
            <img src="{{ asset('medias/thetwin-logo.png') }}" alt="The Twin" height="36">
        </a>
        <p class="footer__text">Projet tutoré 2025–2026 · Université de Limoges</p>
    </footer>
</body>
</html>
