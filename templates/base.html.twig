<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}The Twin{% endblock %}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    {% block stylesheets %}
        {{ encore_entry_link_tags('app') }}
    {% endblock %}
    {% block javascripts %}
        {{ encore_entry_script_tags('app') }}
    {% endblock %}
</head>
<body>
    <nav>
        <a href="{{ path('app_home') }}" class="nav-logo">The Twin</a>
        <div class="nav-links">
            <a href="#">Corpo</a>
            <a href="#">Solo</a>
            {% if app.user %}
                <a href="{{ path('app_logout') }}" class="btn-nav">Déconnexion</a>
            {% else %}
                <a href="{{ path('app_login') }}" class="btn-nav">Compte</a>
            {% endif %}
        </div>
    </nav>

    {% block body %}{% endblock %}
</body>
</html>
