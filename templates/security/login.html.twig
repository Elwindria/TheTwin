{% extends 'base.html.twig' %}

{% block title %}Connexion — The Twin{% endblock %}

{% block body %}
<div class="auth-page">
    <div class="auth-card">
        <h1>Connexion</h1>
        <p class="subtitle">Bon retour sur The Twin</p>

        {% if error %}
            <div class="alert-error">{{ error.messageKey|trans(error.messageData, 'security') }}</div>
        {% endif %}

        <form method="post">
            <div class="form-group">
                <label for="username">Nom d'utilisateur</label>
                <input type="text" id="username" name="username" value="{{ last_username }}" autocomplete="username" required autofocus>
            </div>

            <div class="form-group">
                <label for="password">Mot de passe</label>
                <input type="password" id="password" name="password" autocomplete="current-password" required>
            </div>

            <input type="hidden" name="_csrf_token" data-controller="csrf-protection" value="{{ csrf_token('authenticate') }}">

            <div class="form-group">
                <label class="checkbox-row">
                    <input type="checkbox" name="_remember_me">
                    Se souvenir de moi
                </label>
            </div>

            <button type="submit" class="btn-primary">Se connecter</button>
        </form>

        <hr class="auth-divider">

        <p class="auth-footer">
            Pas encore de compte ? <a href="{{ path('app_register') }}">S'inscrire</a>
        </p>
    </div>
</div>
{% endblock %}
